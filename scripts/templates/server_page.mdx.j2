{% for rs in related_servers %}
  <Card title="{{ rs.name }}" href="/server-catalog/{{ rs.slug }}" icon={{ '"' + rs.logo_url + '"' if rs.logo_url else '"server"' }} />
{% endfor %}
</CardGroup>
{% endif %}
